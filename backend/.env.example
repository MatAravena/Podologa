# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:password@localhost:5432/podologa

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Get from Meta for Developers > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=my_custom_verify_token
WHATSAPP_API_TOKEN=

# ── Social — Facebook ─────────────────────────────────────────────────────────
# Long-lived Page Access Token from Meta Business Suite
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# ── Social — Instagram ────────────────────────────────────────────────────────
# Instagram Business Account ID linked to the Facebook Page
IG_BUSINESS_ACCOUNT_ID=
IG_ACCESS_TOKEN=

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to use dev/print mode (no real emails sent)
# Gmail example: smtp.gmail.com port 587 (use App Password, not real password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=contacto@libelula.cl

# ── Google Calendar ──────────────────────────────────────────────────────────
# Leave empty to disable Calendar sync (integration is fully optional)
# 1. Create a Google Cloud project + enable Calendar API
# 2. Create OAuth2 credentials (Desktop app type)
# 3. Run `python scripts/gcal_auth.py` once to get the refresh token
GOOGLE_CALENDAR_ID=primary
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Cloudinary (media storage) ───────────────────────────────────────────────
# Get from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── AI — Anthropic ────────────────────────────────────────────────────────────
# Used to auto-generate social media captions. Leave empty to disable.
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development   # development | production

# Comma-separated extra CORS origins (used in production to allow the frontend domain)
# Example: CORS_EXTRA_ORIGINS=https://libelula.cl,https://www.libelula.cl
CORS_EXTRA_ORIGINS=
